# Copy to .env and fill in the values you want. Keys stay SERVER-SIDE only;
# the browser never receives them.

# Port the Bun server listens on (default 8787).
PORT=8787

# AI pattern generator. Set ONE of these to enable the AI panel.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model override (default: claude-sonnet-4-6 for Anthropic, gpt-4o for OpenAI)
GOVEE_AI_MODEL=
