# Copy to .env and fill in your Govee Cloud Developer API key.
# Get one from the Govee Home app: Profile -> Settings -> Apply for API Key.
# The key stays SERVER-SIDE only. The browser never receives it.
GOVEE_API_KEY=your-key-here

# Optional: port the Bun proxy listens on (default 8787)
PORT=8787

# Optional: AI pattern generator. Set ONE of these (key stays server-side).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model override (default: claude-opus-4-8 for Anthropic, gpt-4o for OpenAI)
GOVEE_AI_MODEL=
